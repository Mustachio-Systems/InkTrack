{
  "name": "inktrack-worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create inktrack-db",
    "db:migrate:local": "wrangler d1 execute inktrack-db --local --file=./schema.sql",
    "db:migrate:remote": "wrangler d1 execute inktrack-db --remote --file=./schema.sql"
  },
  "devDependencies": {
    "wrangler": "^4.4.0"
  }
}
